# * milieu podman configuration
# * Generated from etc/containers/containers.conf.in by build.sh
# ! Do not edit this file — edit etc/containers/containers.conf.in instead

[engine]
helper_binaries_dir = ["@MILIEU_DIR@/libexec/podman-static/bin"]
conmon_path = ["@MILIEU_DIR@/libexec/podman-static/bin/conmon"]

[network]
network_backend = "netavark"
netavark_plugin_dirs = ["@MILIEU_DIR@/libexec/podman-static/bin"]
dns_bind_port = 5533
