# shellcheck shell=sh
# * milieu environment profile

export HOME="/home/unix"
export ENV_ROOT="$HOME/.milieu"
MILIEU_DIR="$(pwd)"
export MILIEU_DIR
export PAGER="${MILIEU_DIR}/bin/less"
export MANPAGER="${MILIEU_DIR}/bin/less"

# * Go toolchain — GOROOT points into src/go-dist (downloaded by build.sh)
export GOROOT="${MILIEU_DIR}/src/go-dist"
export GOPATH="$ENV_ROOT/gopath"
export GOCACHE="$ENV_ROOT/gopath/cache"
export GOENV="$ENV_ROOT/gopath/env"
export CARGO_HOME="$ENV_ROOT/.cargo"
export RUSTUP_HOME="$ENV_ROOT/.rustup"

# * uv — keep all state inside the milieu directory
export UV_HOME="$ENV_ROOT/uv-home"
export UV_CACHE_DIR="$ENV_ROOT/uv-home/cache"
export UV_DATA_DIR="$ENV_ROOT/uv-home/data"
export UV_PYTHON_INSTALL_DIR="$ENV_ROOT/uv-home/python"
export UV_TOOL_DIR="$ENV_ROOT/uv-home/tools"
export UV_TOOL_BIN_DIR="$ENV_ROOT/uv-home/bin"

# * nix-portable — store inside ENV_ROOT instead of $HOME
export NP_LOCATION="$ENV_ROOT"

# * XDG base dirs — redirect podman, distrobox, and other XDG-aware tools into ENV_ROOT
export XDG_DATA_HOME="$ENV_ROOT/.local/share"
export XDG_CONFIG_HOME="$ENV_ROOT/.config"
export XDG_CACHE_HOME="$ENV_ROOT/.cache"
export XDG_RUNTIME_DIR="$ENV_ROOT/run"
mkdir -p "$XDG_RUNTIME_DIR"

# * Podman — static config generated by build.sh from etc/containers/containers.conf.in;
# * storage location is derived automatically from XDG_DATA_HOME (no storage.conf needed).
export CONTAINERS_CONF="${MILIEU_DIR}/etc/containers/containers.conf"
export CONTAINERS_REGISTRIES_CONF="${MILIEU_DIR}/etc/containers/registries.conf"

# * Distrobox — use milieu's podman; keep container homes in ENV_ROOT
export DBX_CONTAINER_MANAGER="podman"
export DBX_CONTAINER_HOME_PREFIX="$ENV_ROOT/distrobox"

export PATH="$MILIEU_DIR/libexec/podman-static/bin:$CARGO_HOME/bin:$GOPATH/bin:$UV_TOOL_BIN_DIR:$PATH"

# * Run tools sync on launch if needed
if [ -x "${MILIEU_DIR}/bin/milieu-sync" ]; then
    "${MILIEU_DIR}/bin/milieu-sync"
fi
