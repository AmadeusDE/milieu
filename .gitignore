# Ignore everything by default
*

# Always track these core files
!.gitignore
!build.sh
!install-links.sh
!LLM_REFERENCE.md
!milieu-sh
!milieu-sh-sys
!milieu-sh-overlay
!package.sh

# Track the configs/ directory and all its contents
!configs/
!configs/**

# Track the etc/ directory and all its contents
!etc/
!etc/mkshrc
!etc/profile
!etc/zshrc

# Track the script/ directory and all its contents
!script/
!script/**