# Ignore everything by default
*

# Track the LLM files
!CONTEXT.md
!.agents/
!.agents/**

# Always track these core files
!.gitignore
!build.sh
!check.sh
!clean.sh
!install-links.sh
!Makefile
!milieu-sh
!milieu-sh-sys
!milieu-sh-overlay
!package.sh

# Track the configs/ directory and all its contents
!configs/
!configs/**

# Track the etc/ directory and all its contents
!etc/
!etc/containers/
!etc/containers/containers.conf.in
!etc/mkshrc
!etc/profile
!etc/zshrc

# Track the script/ directory and all its contents
!script/
!script/**