#!/bin/sh
# milieu-sh: Enter the static milieu environment with an ISOLATED path.
# Only milieu's bin/ is on PATH — system tools are not accessible.

BASE_DIR="$(cd "$(dirname "$0")" && pwd)"
export PATH="$BASE_DIR/bin"
export SHELL="$BASE_DIR/bin/mksh"
export ENV="$BASE_DIR/etc/mkshrc"

if [ $# -gt 0 ]; then
    exec "$BASE_DIR/bin/mksh" "$@"
else
    exec "$BASE_DIR/bin/mksh" -i
fi
